{
  "name": "web-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "next lint && npm run lint:css && npm run lint:css-vars",
    "lint:css": "stylelint 'src/**/*.css' --allow-empty-input",
    "lint:css-vars": "node scripts/check-css-vars.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:stress": "playwright test tests/e2e/terminal-stress",
    "test:stress:headed": "playwright test tests/e2e/terminal-stress --headed",
    "test:stress:debug": "playwright test tests/e2e/terminal-stress --debug",
    "test:report": "playwright show-report",
    "size-limit": "size-limit",
    "test:benchmark": "playwright test tests/e2e/benchmarks/",
    "test:benchmark:throughput": "playwright test tests/e2e/benchmarks/terminal-throughput.spec.ts",
    "test:benchmark:latency": "playwright test tests/e2e/benchmarks/rpc-latency.spec.ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ansi-to-html": "^0.7.2",
    "codemirror": "^6.0.2",
    "it-ws": "^6.1.5",
    "lzma-js": "^1.0.1",
    "next": "15.3.2",
    "react": "^19.0.0",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.63.0",
    "react-redux": "^9.2.0",
    "shiki": "^4.0.2",
    "zod": "^4.1.11"
  },
  "size-limit": [
    {
      "name": "Total JS bundle",
      "path": "out/_next/static/chunks/**/*.js",
      "limit": "5 MB",
      "gzip": false
    },
    {
      "name": "Framework chunk (React)",
      "path": "out/_next/static/chunks/framework-*.js",
      "limit": "650 KB",
      "gzip": false
    },
    {
      "name": "Main app chunk",
      "path": "out/_next/static/chunks/main-*.js",
      "limit": "400 KB",
      "gzip": false
    }
  ],
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@playwright/test": "^1.57.0",
    "@size-limit/file": "^11.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/next-plugin": "^2.5.1",
    "eslint": "^9",
    "eslint-config-next": "15.3.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "size-limit": "^11.0.0",
    "stylelint": "^17.6.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-jest": "^29.4.4",
    "typescript": "^5.9.3",
    "wait-on": "^8.0.1"
  }
}
