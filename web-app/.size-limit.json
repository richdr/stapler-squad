[
  {
    "name": "Total JS bundle",
    "path": "out/_next/static/chunks/**/*.js",
    "limit": "5 MB",
    "ignore": ["**/*.map"],
    "gzip": false
  },
  {
    "name": "Framework chunk (React)",
    "path": "out/_next/static/chunks/framework-*.js",
    "limit": "650 KB",
    "gzip": false
  },
  {
    "name": "Main app chunk",
    "path": "out/_next/static/chunks/main-*.js",
    "limit": "400 KB",
    "gzip": false
  }
]
